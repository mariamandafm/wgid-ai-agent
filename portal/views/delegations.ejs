<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8" />
  <title>Delegações ativas</title>
  <style>
    * { box-sizing: border-box; }
    body {
      font-family: -apple-system, "Segoe UI", Roboto, sans-serif;
      background: #f4f5f7;
      color: #1f2328;
      margin: 0;
      padding: 40px 20px;
    }
    .container { max-width: 600px; margin: 0 auto; }
    h1 { font-size: 22px; margin-bottom: 4px; }
    .subtitle { color: #57606a; margin-bottom: 24px; }
    .card {
      background: #ffffff;
      border: 1px solid #d8dee4;
      border-radius: 10px;
      padding: 20px 24px;
    }
    .card h2 { margin: 0 0 12px; font-size: 17px; }
    .label { font-size: 12px; font-weight: 600; color: #57606a; margin: 12px 0 6px; text-transform: uppercase; letter-spacing: 0.03em; }
    .scopes-row { display: flex; gap: 8px; flex-wrap: wrap; }
    .badge.allow {
      display: inline-block;
      font-size: 12px;
      font-weight: 600;
      padding: 3px 10px;
      border-radius: 999px;
      background: #dafbe1; color: #1a7f37; border: 1px solid #aceebb;
    }
    .empty {
      background: #fff;
      border: 1px dashed #d8dee4;
      border-radius: 10px;
      padding: 28px;
      text-align: center;
      color: #57606a;
    }
    .btn {
      display: inline-block;
      padding: 9px 16px;
      border-radius: 6px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      border: none;
      margin-top: 16px;
    }
    .btn.danger { background: #fff; color: #cf222e; border: 1px solid #ffc1bc; }
    .btn.danger:hover { background: #ffebe9; }
    .btn.link { background: #1f2328; color: #fff; text-decoration: none; }
  </style>
</head>
<body>
  <div class="container">
    <h1>Delegações ativas</h1>
    <p class="subtitle">Agentes atualmente autorizados a agir em seu nome.</p>

    <% if (delegation) { %>
      <div class="card">
        <h2><%= delegation.agent.name %></h2>

        <div class="label">Escopos delegados</div>
        <div class="scopes-row">
          <% delegation.scope.split(' ').forEach(scope => { %>
            <span class="badge allow"><%= scope %></span>
          <% }) %>
        </div>

        <form method="POST" action="/revoke">
          <button class="btn danger" type="submit">Revogar</button>
        </form>
      </div>
    <% } else { %>
      <div class="empty">
        Nenhuma delegação ativa.
        <div><a class="btn link" href="/">Ver agentes disponíveis</a></div>
      </div>
    <% } %>
  </div>
</body>
</html>
