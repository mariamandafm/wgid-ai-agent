<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8" />
  <title>Consentimento de Delegação</title>
  <style>
    * { box-sizing: border-box; }
    body {
      font-family: -apple-system, "Segoe UI", Roboto, sans-serif;
      background: #f4f5f7;
      color: #1f2328;
      margin: 0;
      padding: 40px 20px;
    }
    .container { max-width: 560px; margin: 0 auto; }
    h1 { font-size: 22px; margin-bottom: 4px; }
    .subtitle { color: #57606a; margin-bottom: 24px; }
    .card {
      background: #ffffff;
      border: 1px solid #d8dee4;
      border-radius: 10px;
      padding: 24px 28px;
    }
    .row { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #eaeef2; }
    .row:last-child { border-bottom: none; }
    .row .k { color: #57606a; font-size: 14px; }
    .row .v { font-weight: 600; font-size: 14px; text-align: right; }
    .label { font-size: 12px; font-weight: 600; color: #57606a; margin: 16px 0 6px; text-transform: uppercase; letter-spacing: 0.03em; }
    .scopes-row { display: flex; gap: 8px; flex-wrap: wrap; }
    .badge.allow {
      display: inline-block;
      font-size: 12px;
      font-weight: 600;
      padding: 3px 10px;
      border-radius: 999px;
      background: #dafbe1; color: #1a7f37; border: 1px solid #aceebb;
    }
    .actions { margin-top: 24px; display: flex; gap: 10px; }
    .btn {
      flex: 1;
      text-align: center;
      padding: 10px 18px;
      border-radius: 6px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      border: none;
    }
    .btn.primary { background: #1f2328; color: #fff; }
    .btn.primary:hover { background: #32383f; }
    .btn.secondary { background: #fff; color: #1f2328; border: 1px solid #d8dee4; }
  </style>
</head>
<body>
  <div class="container">
    <h1>Confirmar delegação</h1>
    <p class="subtitle">Revise o que o agente poderá fazer em seu nome antes de autorizar.</p>

    <div class="card">
      <div class="row"><span class="k">Agente</span><span class="v"><%= agent.name %></span></div>
      <div class="row"><span class="k">Validade</span><span class="v"><%= validityDays %> dias</span></div>

      <div class="label">Escopos delegados</div>
      <div class="scopes-row">
        <% agent.allowedScopes.forEach(scope => { %>
          <span class="badge allow"><%= scope %></span>
        <% }) %>
      </div>

      <form method="POST" action="/authorize" class="actions">
        <a class="btn secondary" href="/">Cancelar</a>
        <button class="btn primary" type="submit">Confirmar delegação</button>
      </form>
    </div>
  </div>
</body>
</html>
