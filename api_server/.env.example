# URL pública do Keycloak (para logs e exibição)
KEYCLOAK_URL=http://localhost:8080

# URL interna do Keycloak (para chamadas servidor-a-servidor)
KEYCLOAK_INTERNAL_URL=http://keycloak:8080

REALM=agents

# Client confidencial da API (usado para Token Introspection). Secret já
# pré-configurado em keycloak/realm-import.json para uso com Docker Compose.
API_CLIENT_ID=api-server
API_CLIENT_SECRET=api-server-dev-secret

PORT=3001

# Arquivo de audit log
AUDIT_LOG_FILE=./audit.log